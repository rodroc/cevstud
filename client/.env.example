# Supabase — copy to .env.local and fill in your project values.
# Find these in: Supabase dashboard → Project Settings → API

# Used client-side (safe to expose) and server-side for anon inserts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — grants full DB access, NEVER expose to the browser or commit
SUPABASE_SERVICE_ROLE_KEY=

# Optional: gate /admin behind ?secret=<value> until proper auth is added
ADMIN_SECRET=
